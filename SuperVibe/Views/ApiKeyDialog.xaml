<Window x:Class="SuperVibe.Views.ApiKeyDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LLM API Key" Height="280" Width="420"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#1a1a2e">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Provider selection -->
        <TextBlock Grid.Row="0" Text="Provider" Foreground="#00d4ff" FontSize="14" Margin="0,0,0,5"/>
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <RadioButton x:Name="ClaudeRadio" Content="Claude (Anthropic)" Foreground="White"
                         IsChecked="True" Checked="OnProviderChanged" Margin="0,0,20,0"/>
            <RadioButton x:Name="GeminiRadio" Content="Gemini (Google)" Foreground="White"
                         Checked="OnProviderChanged"/>
        </StackPanel>

        <!-- API Key input -->
        <TextBlock Grid.Row="2" x:Name="KeyLabel" Text="Anthropic API Key"
                   Foreground="#00d4ff" FontSize="14" Margin="0,0,0,5"/>
        <TextBox Grid.Row="3" x:Name="KeyInput" Height="60"
                 FontFamily="Consolas" FontSize="12"
                 TextWrapping="Wrap" AcceptsReturn="False"
                 Background="#16213e" Foreground="White" BorderBrush="#00d4ff"
                 Padding="5"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Cancel" Width="80" Height="30" Margin="0,0,10,0" Click="OnCancel"
                    Background="#333" Foreground="White" BorderBrush="#555"/>
            <Button Content="Save" Width="80" Height="30" Click="OnSave"
                    Background="#00d4ff" Foreground="Black" BorderBrush="#00d4ff" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>
