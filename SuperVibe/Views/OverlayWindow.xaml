<Window x:Class="SuperVibe.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" ShowActivated="False"
        Width="600" Height="300"
        WindowStartupLocation="Manual">
    <Grid x:Name="RootGrid">
        <!-- Recording HUD -->
        <Border x:Name="RecordingPanel" Visibility="Collapsed"
                Background="#0A0A14" CornerRadius="16" BorderThickness="1"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Padding="22,14">
            <Border.Effect>
                <DropShadowEffect x:Name="RecordingShadow" Color="#00D4FF" BlurRadius="16" ShadowDepth="0" Opacity="0.15"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <!-- Waveform bars -->
                <Canvas x:Name="WaveformCanvas" Width="120" Height="50" Margin="10,0"/>
            </StackPanel>
        </Border>

        <!-- Text Card (Transcription/Translation) -->
        <Border x:Name="TextPanel" Visibility="Collapsed"
                Background="#0A0A14" CornerRadius="14" BorderThickness="1.5"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                MaxWidth="560" Padding="24">
            <Border.Effect>
                <DropShadowEffect x:Name="TextShadow" Color="#00D4FF" BlurRadius="20" ShadowDepth="0" Opacity="0.3"/>
            </Border.Effect>
            <StackPanel>
                <!-- ASR Section -->
                <StackPanel x:Name="AsrSection">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                        <Ellipse x:Name="SpinDot1" Width="4" Height="4" Margin="0,0,3,0"/>
                        <Ellipse x:Name="SpinDot2" Width="4" Height="4" Margin="0,0,3,0"/>
                        <Ellipse x:Name="SpinDot3" Width="4" Height="4"/>
                        <TextBlock x:Name="AsrLabel" Text="TRANSCRIBING"
                                   FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                                   Margin="8,0,0,0"/>
                    </StackPanel>
                    <TextBlock x:Name="AsrTextBlock" TextWrapping="Wrap" FontFamily="Consolas" FontSize="14"
                               Foreground="#E6FFFFFF" MaxWidth="520" TextAlignment="Left"
                               Margin="0,0,0,4"/>
                </StackPanel>

                <!-- Divider (for translation/polish) -->
                <Rectangle x:Name="Divider" Height="1" Margin="0,8" Visibility="Collapsed"/>

                <!-- GPT Section (for translation/polish) -->
                <StackPanel x:Name="GptSection" Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                        <TextBlock x:Name="GptLabel" Text="TRANSLATING"
                                   FontFamily="Consolas" FontSize="11" FontWeight="Bold"/>
                    </StackPanel>
                    <TextBlock x:Name="GptTextBlock" TextWrapping="Wrap" FontFamily="Consolas" FontSize="14"
                               Foreground="#E6FFFFFF" MaxWidth="520" TextAlignment="Left"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Error Card -->
        <Border x:Name="ErrorPanel" Visibility="Collapsed"
                Background="#0A0A14" CornerRadius="14" BorderThickness="1.5"
                BorderBrush="#FF3333" HorizontalAlignment="Center" VerticalAlignment="Center"
                Padding="24">
            <Border.Effect>
                <DropShadowEffect Color="#FF3333" BlurRadius="20" ShadowDepth="0" Opacity="0.3"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="⚠" FontSize="14" Foreground="#FF3333" Margin="0,0,8,0" VerticalAlignment="Center"/>
                <TextBlock x:Name="ErrorText" Text="ERROR" FontFamily="Consolas" FontSize="12"
                           FontWeight="Bold" Foreground="#FF3333"/>
            </StackPanel>
        </Border>

        <!-- Scan lines overlay -->
        <Canvas x:Name="ScanLinesCanvas" IsHitTestVisible="False" Opacity="0.015"/>
    </Grid>
</Window>
